# ============================================================
# LudusCartographer — 環境変数設定テンプレート
# このファイルを crawler/config/.env にコピーして使用してください
# ============================================================

# ------------------------------------------------------------
# iOS デバイス設定
# ------------------------------------------------------------

# IOS_UDID: 接続する iPhone の UDID（省略可能 — 自動検出）
#
# 【UDID 自動検出の仕組み】
# IOS_UDID が未設定の場合、以下の順序で自動的に UDID を取得します:
#   1. 環境変数 IOS_UDID （最優先）
#   2. idevice_id -l （libimobiledevice — ペアリング済みが必要）
#   3. ioreg -p IOUSB の USB Serial Number （「信頼」未承認でも取得可能）
#
# 自動検出が失敗する主な原因:
#   - USBケーブルが抜けている
#   - iPhone画面に「このコンピュータを信頼しますか?」が表示されたままの場合
#     → iPhone の「信頼」をタップすると idevice_id で検出されるようになります
#
# 手動で設定する場合 (UDID確認方法: Xcode > Devices and Simulators):
# IOS_UDID=00008120-000A1234ABCD1234

# IOS_BUNDLE_ID: ターゲットアプリの Bundle ID（必須）
IOS_BUNDLE_ID=com.example.mygame

# IOS_DEVICE_NAME: デバイス表示名（任意 — デフォルト: "iPhone"）
# IOS_DEVICE_NAME=iPhone 15 Pro

# IOS_PLATFORM_VERSION: iOS バージョン（任意 — 省略時は自動）
# IOS_PLATFORM_VERSION=17.4

# ------------------------------------------------------------
# Appium サーバー設定（任意）
# ------------------------------------------------------------
# APPIUM_HOST=127.0.0.1
# APPIUM_PORT=4723

# ------------------------------------------------------------
# Google Cloud / Vertex AI 設定（任意 — 未設定時は AI解析スキップ）
# ------------------------------------------------------------
# 認証は ADC (Application Default Credentials) を自動使用します。
# 事前に `gcloud auth application-default login` を実行してください。
#
# GCP_PROJECT_ID=my-gcp-project-id
# GCP_LOCATION=asia-northeast1

# ------------------------------------------------------------
# MySQL 接続設定（任意 — 未設定時は DB 保存スキップ）
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ludus_cartographer
DB_USER=root
DB_PASSWORD=your_password_here
