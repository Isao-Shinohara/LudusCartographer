{
    "name": "ludus-cartographer/web",
    "description": "Web search UI for LudusCartographer",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "twig/twig": "^3.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "LudusCartographer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LudusCartographer\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
