<!DOCTYPE html>
<html lang="ja" class="h-full bg-gray-950">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}LudusCartographer{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: { DEFAULT: '#7c3aed', dark: '#5b21b6', light: '#a78bfa' }
                    }
                }
            }
        }
    </script>
</head>
<body class="h-full text-gray-100 font-sans">

<!-- Header -->
<header class="bg-gray-900 border-b border-gray-800 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-4 flex items-center gap-3">
        <span class="text-2xl">🗺️</span>
        <div>
            <h1 class="text-xl font-bold text-brand-light tracking-wide">LudusCartographer</h1>
            <p class="text-xs text-gray-500">モバイルゲーム UI マップ</p>
        </div>
    </div>
</header>

<!-- Main -->
<main class="max-w-7xl mx-auto px-4 py-8">
    {% block content %}{% endblock %}
</main>

<!-- Footer -->
<footer class="border-t border-gray-800 mt-16">
    <div class="max-w-7xl mx-auto px-4 py-4 text-center text-xs text-gray-600">
        LudusCartographer &copy; 2026 — powered by Appium + PaddleOCR
    </div>
</footer>

</body>
</html>
